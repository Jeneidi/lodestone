# =============================================================================
# Lodestone — environment variable reference
# =============================================================================
# Copy this file to .env and fill in values as needed.
# .env is git-ignored; never commit real secrets.
#
# All variables use the LODESTONE_ prefix (handled by pydantic-settings).
# =============================================================================

# ---------------------------------------------------------------------------
# Generation / LLM  (OFF by default — no cost, no API key required)
# ---------------------------------------------------------------------------

# Master switch for Claude-powered answer generation.
# When false (default), a free extractive fallback is used instead.
# Set to "true" to enable Anthropic API calls.
LODESTONE_GENERATION_ENABLED=false

# Anthropic API key — required only when LODESTONE_GENERATION_ENABLED=true.
# Obtain from https://console.anthropic.com/
# Can also be set as ANTHROPIC_API_KEY (without the LODESTONE_ prefix).
LODESTONE_ANTHROPIC_API_KEY=

# Claude model used for generation when enabled.
# Default matches the current stable Sonnet model.
LODESTONE_GENERATION_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Retrieval models  (downloaded once from HuggingFace Hub, then cached)
# ---------------------------------------------------------------------------

# Bi-encoder for dense retrieval (sentence-transformers compatible).
# Defaults to the 22M-parameter MiniLM-L6-v2 — fast on CPU.
# LODESTONE_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Cross-encoder for reranking queries vs. retrieved chunks.
# LODESTONE_RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# Cross-encoder NLI model for answer faithfulness scoring.
# LODESTONE_NLI_MODEL_NAME=cross-encoder/nli-deberta-v3-xsmall

# ---------------------------------------------------------------------------
# Retrieval hyper-parameters
# ---------------------------------------------------------------------------

# Number of chunks returned by the retriever before reranking.
# LODESTONE_TOP_K=10

# Number of chunks retained after cross-encoder reranking.
# LODESTONE_RERANK_TOP_K=5

# RRF smoothing constant (higher → less impact from top ranks).
# LODESTONE_RRF_K=60

# Hybrid fusion interpolation weight (0.0=BM25 only, 1.0=dense only).
# LODESTONE_HYBRID_ALPHA=0.5

# ---------------------------------------------------------------------------
# File system paths
# ---------------------------------------------------------------------------

# Root directory for raw and processed dataset files.
# LODESTONE_DATA_DIR=data

# Directory where evaluation reports and plots are written.
# LODESTONE_REPORTS_DIR=evals/reports
